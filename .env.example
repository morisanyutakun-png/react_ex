# Database
# Local development: leave empty to use SQLite (./data/examgen.db)
# Production (Neon): postgresql://user:pass@ep-xxx.region.neon.tech/dbname?sslmode=require
DATABASE_URL=

# CORS — comma-separated origins allowed by the backend.
# Use "*" for local development; restrict in production.
# Example: https://your-app.vercel.app,http://localhost:3000
CORS_ALLOW_ORIGINS=*

# Embedding / model
PGVECTOR_DIM=768
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_VERSION=v1

# RAG
RAG_PROFILE_PATH=./configs/rag_profiles.yaml
RAG_DEFAULT_KIND_PRIORITY=stem,normalized_text,solution_outline,latex_signature

# PDF engine: tectonic or pdflatex
PDF_ENGINE=tectonic

LOG_LEVEL=INFO

# ──────────────────────────────────────────────
# Frontend (Next.js / Vercel)
# ──────────────────────────────────────────────
# API_BASE_URL — used by Next.js rewrites (server-side proxy).
# Local: http://localhost:8000  Production: https://zeroth-aubree-yutamori-95ef4ba2.koyeb.app
API_BASE_URL=http://localhost:8000

# NEXT_PUBLIC_API_BASE — used by browser when calling backend directly (CORS required).
# Usually leave empty (use server-side proxy via rewrites).
NEXT_PUBLIC_API_BASE=

# ──────────────────────────────────────────────
# OpenAI API
# ──────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# ──────────────────────────────────────────────
# AI Usage Limits & Admin
# ──────────────────────────────────────────────
# Max AI generations per user (default: 10)
AI_GENERATION_LIMIT=10
# Max questions per single generation (cost control, default: 3)
MAX_QUESTIONS_PER_GENERATION=3
# Admin password to unlock unlimited AI usage
ADMIN_PASSWORD=

# ──────────────────────────────────────────────
# JWT Authentication
# ──────────────────────────────────────────────
# Secret key for signing JWT tokens (auto-generated if not set; set for persistent sessions across restarts)
JWT_SECRET=
# Set to true in production to require JWT for all non-public API endpoints
REQUIRE_AUTH=false
